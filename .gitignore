# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

#  문항 번호에 따른 라우팅을 파이썬에서 하는데 번호에 따른 직접 요청하는게 낫지 않나
#  각각의 역할을 한다.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# env
.env